# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development   # development | production | test

# ─── Database ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority

# ─── Authentication ───────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CLIENT_URL=http://localhost:5173

# ─── ImageKit (Cloud Image CDN) ───────────────────────────────────────────────
# Get these from: https://imagekit.io → Dashboard → Developer Options
IMAGEKIT_PUBLIC_KEY=public_REPLACE_ME
IMAGEKIT_PRIVATE_KEY=private_REPLACE_ME
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/YOUR_ID

# ─── Seed Admin Account ───────────────────────────────────────────────────────
ADMIN_NAME=System Administrator
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=ChangeMe@123
ADMIN_PHONE=0000000000
ADMIN_CONTACT_EMAIL=admin@yourdomain.com
